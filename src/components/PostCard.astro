---
import type { Post } from '@/lib/posts'
import { url } from '@/lib/url'

interface Props {
  post: Post
  index: number
  compact?: boolean
}

const { post, index, compact = false } = Astro.props
const data = post.data
---
<a href={url(`/posts/${post.id}`)} class={compact ? 'post-card compact' : 'post-card'}>
  <div class="post-card-index">{String(index + 1).padStart(2, '0')}</div>
  {!compact && (
    <div class="post-card-media">
      {data.cover && <img src={url(data.cover)} alt="" loading="lazy" />}
    </div>
  )}
  <div class="post-card-body">
    <div class="post-meta-line">
      <span>{data.category}</span>
      <span>{data.date}</span>
      {data.readingTime && <span>{data.readingTime}</span>}
    </div>
    <h2>{data.title}</h2>
    <p>{data.excerpt}</p>
    <div class="tag-row">
      {data.tags.map((tag) => <span>#{tag}</span>)}
    </div>
  </div>
  <span class="post-card-arrow" aria-hidden="true">→</span>
</a>
