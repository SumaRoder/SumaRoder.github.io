---
import PageShell from '@/layouts/PageShell.astro'
import SectionKicker from '@/components/SectionKicker.astro'
import PostCard from '@/components/PostCard.astro'
import { SITE } from '@/consts'
import { getPublishedPosts, getAllTags, type Post } from '@/lib/posts'
import { url } from '@/lib/url'

export async function getStaticPaths() {
  const posts = await getPublishedPosts()
  const tags = getAllTags(posts)
  return tags.map((tag) => ({
    params: { tag },
    props: { tag, posts: posts.filter((p) => p.data.tags.includes(tag)) },
  }))
}

interface Props {
  tag: string
  posts: Post[]
}

const { tag, posts } = Astro.props
---
<PageShell title={`#${tag} · ${SITE.brand.name}`}>
  <main class="page-main">
    <section class="page-hero">
      <SectionKicker index="T-01" label="TAG RESULT" />
      <h1>#{tag}</h1>
      <p>当前标签下共有 {posts.length} 篇文章。</p>
    </section>

    <section class="list-section">
      {posts.map((post, index) => <PostCard post={post} index={index} />)}
      {posts.length === 0 && (
        <div class="empty-state">
          <p>没有找到这个标签。</p>
          <a href={url('/tags')}>返回标签索引</a>
        </div>
      )}
    </section>
  </main>
</PageShell>
